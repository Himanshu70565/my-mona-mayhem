		<style>
			/* CSS Variables for Retro Arcade Theme */
			:root {
				--bg-dark: #0a0a1a;
				--accent-green: #5fed83;
				--accent-purple: #8a2be2;
				--text-primary: #5fed83;
				--text-secondary: #8a2be2;
				--glow-green: rgba(95, 237, 131, 0.5);
				--glow-purple: rgba(138, 43, 226, 0.5);
			}

			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}

			/* CRT Scanline Effect */
			@keyframes scanlines {
				0% { transform: translateY(0); }
				100% { transform: translateY(10px); }
			}

			body {
				font-family: 'Press Start 2P', cursive;
				background: var(--bg-dark);
				min-height: 100vh;
				display: flex;
				justify-content: center;
				align-items: center;
				padding: 20px;
				color: var(--text-primary);
				position: relative;
				overflow-x: hidden;
			}

			/* CRT Scanline Background Overlay */
			body::before {
				content: '';
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				background: repeating-linear-gradient(
					0deg,
					rgba(0, 0, 0, 0.15),
					rgba(0, 0, 0, 0.15) 1px,
					transparent 1px,
					transparent 2px
				);
				pointer-events: none;
				animation: scanlines 8s linear infinite;
				z-index: 1;
			}

			body::after {
				content: '';
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				background: radial-gradient(ellipse at center, transparent 0%, rgba(0, 0, 0, 0.3) 100%);
				pointer-events: none;
				z-index: 0;
			}

			/* Neon Glow Pulsing Animation */
			@keyframes neon-glow {
				0%, 100% {
					text-shadow: 
						0 0 10px var(--accent-green),
						0 0 20px var(--accent-green),
						0 0 30px var(--accent-green),
						0 0 40px var(--accent-green);
				}
				50% {
					text-shadow: 
						0 0 5px var(--accent-green),
						0 0 10px var(--accent-green),
						0 0 15px var(--accent-green),
						0 0 20px var(--accent-green);
				}
			}

			/* Gradient Color Shift Animation for VS Badge */
			@keyframes gradient-shift {
				0%, 100% { 
					background: linear-gradient(45deg, var(--accent-green), var(--accent-purple));
					box-shadow: 0 0 20px var(--glow-green), 0 0 40px var(--glow-purple);
				}
				50% { 
					background: linear-gradient(45deg, var(--accent-purple), var(--accent-green));
					box-shadow: 0 0 20px var(--glow-purple), 0 0 40px var(--glow-green);
				}
			}

			/* Shimmer Overlay Animation */
			@keyframes shimmer {
				0% { transform: translateX(-100%); }
				100% { transform: translateX(100%); }
			}

			/* Float-In Animation */
			@keyframes float-in {
				from {
					opacity: 0;
					transform: translateY(30px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			/* Color Shift Loading Animation */
			@keyframes color-shift {
				0%, 100% { color: var(--accent-green); }
				50% { color: var(--accent-purple); }
			}

			/* Hover Glow for Contribution Squares */
			@keyframes square-glow {
				0% { box-shadow: 0 0 5px currentColor; }
				50% { box-shadow: 0 0 15px currentColor, 0 0 25px currentColor; }
				100% { box-shadow: 0 0 5px currentColor; }
			}

			.container {
